    def __getitem__(self, key: Any) -> Any: ...
    def __setattr__(self, key: Any, value: Any): ...
    def __setitem__(self, key: Any, value: Any): ...
    def __call__(self, *args: Any) -> Any: ...

class GCLua:
    fhk_py: GCPin

class Mem:
    def reset(self): ...

class GCDriver: ...

