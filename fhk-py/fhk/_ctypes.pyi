from fhk.obj import Conv, Subset

__all__ = (
    "interval",
    "space",
    "Mem",
    "SolverState"
)

X = TypeVar("X")

def interval(start: int, num: int) -> int: ...
def space(num: int) -> int: ...
def isunit(ss: int) -> bool: ...
def subsetstr(ss: Subset) -> str: ...
def seq_iterss(mem: Sequence[X], ss: Subset) -> Iterator[X]: ...

class GCPin:
